# VWork environment variables sample
# Copy to .env or export these in the shell/service environment.
# Keep actual secrets out of git.

# SMTP account used by scripts/post_to_hatena.py and scripts/post_to_blogger.py
SMTP_HOST=
SMTP_PORT=
SMTP_FROM=
SMTP_PASSWORD=

# Mail posting destinations
HATENA_POST_EMAIL=
BLOGGER_POST_EMAIL=

# Public publishing / SNS notification endpoints
VWORK_BASE_URL=
VWORK_GITHUB_REMOTE=
VWORK_GH_PAGES_DIR=
AIXSNS_API_URL=
AIXSNS_AUTHOR=

# AI text generation command used by scripts/gen_ai_episodes.py
CLAUDE_BIN=
CLAUDE_MODEL=
CLAUDE_TIMEOUT_SECONDS=

# Optional local / API LLM settings for future generators
LLM_PROVIDER=
OLLAMA_BASE_URL=
OLLAMA_MODEL=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# External research sources
GOOGLE_NEWS_RSS_BASE_URL=
NEWS_SEARCH_LOCALE=
NEWS_SEARCH_REGION=

# Optional video / cross-post integrations used by related workflows
KURAGE_BASE_URL=
KURAGE_API_URL=
KURAGE_VOICE_PRO_URL=
KURAGE_VOICE_PRO_API_URL=
YOUTUBE_CLIENT_SECRETS_FILE=
YOUTUBE_TOKEN_FILE=

# Optional tracking / analytics
GA_MEASUREMENT_ID=
SIMPLETRACK_URL=

# Optional deployment credentials if publishing outside GitHub Pages
FTP_HOST=
FTP_USER=
FTP_PASSWORD=
FTP_REMOTE_DIR=
SSH_AUTH_SOCK=
